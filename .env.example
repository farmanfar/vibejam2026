VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# Optional — only needed for `npm run seed:ghosts` (CLI seeding tool).
# DO NOT prefix with VITE_ — Vite would inline this in the client bundle and
# leak admin access. Find it at Supabase Dashboard → Project Settings → API → service_role.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
